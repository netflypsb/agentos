{
  "name": "agentos-mcp",
  "version": "1.0.0",
  "description": "Essential operating system services for AI agents - persistent memory, format conversion, and structured logging",
  "type": "module",
  "main": "build/index.js",
  "bin": {
    "agentos-mcp": "./build/index.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node build/index.js",
    "dev": "tsx --watch src/index.ts",
    "prepublishOnly": "npm run build && npm run test",
    "test": "jest --config jest.config.cjs",
    "test:watch": "jest --watch --config jest.config.cjs",
    "test:coverage": "jest --coverage --config jest.config.cjs",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "clean": "rimraf build",
    "prepack": "npm run build",
    "postpack": "npm run clean",
    "semantic-release": "semantic-release"
  },
  "files": [
    "build/**",
    "README.md",
    "LICENSE",
    "docs/**"
  ],
  "keywords": [
    "mcp",
    "model-context-protocol",
    "ai",
    "agent",
    "memory",
    "logging",
    "task-management",
    "kv-store",
    "format-converter",
    "sqlite",
    "claude",
    "anthropic"
  ],
  "author": {
    "name": "AgentOS Team",
    "email": "team@agentos-mcp.com",
    "url": "https://agentos-mcp.com"
  },
  "license": "MIT",
  "mcpName": "agentos-mcp",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "sql.js": "^1.11.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.8",
    "@types/jest": "^29.5.8",
    "@types/node": "^20.10.0",
    "@types/sql.js": "^1.4.9",
    "@typescript-eslint/eslint-plugin": "^6.13.0",
    "@typescript-eslint/parser": "^6.13.0",
    "eslint": "^8.54.0",
    "jest": "^29.7.0",
    "rimraf": "^5.0.5",
    "semantic-release": "^22.0.5",
    "ts-jest": "^29.4.6",
    "tsx": "^4.6.0",
    "typescript": "^5.3.0"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=8.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/netflypsb/agentos.git"
  },
  "bugs": {
    "url": "https://github.com/netflypsb/agentos/issues"
  },
  "homepage": "https://github.com/netflypsb/agentos",
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "funding": {
    "type": "individual",
    "url": "https://github.com/sponsors/agentos-mcp"
  }
}
