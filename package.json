{
  "name": "agentos-mcp",
  "version": "1.0.0",
  "description": "Essential operating system services for AI agents",
  "type": "module",
  "main": "build/index.js",
  "bin": {
    "agentos-mcp": "./build/index.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node build/index.js",
    "dev": "tsx --watch src/index.ts",
    "prepublishOnly": "npm run build",
    "test": "jest",
    "lint": "eslint src --ext .ts",
    "clean": "rimraf build"
  },
  "files": [
    "build/**",
    "templates/**",
    "README.md"
  ],
  "keywords": [
    "mcp",
    "ai",
    "agent",
    "memory",
    "logging",
    "task-management"
  ],
  "author": "AgentOS Team",
  "license": "MIT",
  "mcpName": "agentos-mcp",
  "dependencies": {
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@types/better-sqlite3": "^7.6.8",
    "@typescript-eslint/eslint-plugin": "^6.13.0",
    "@typescript-eslint/parser": "^6.13.0",
    "eslint": "^8.54.0",
    "jest": "^29.7.0",
    "rimraf": "^5.0.5",
    "tsx": "^4.6.0",
    "typescript": "^5.3.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/agentos-mcp/server.git"
  },
  "bugs": {
    "url": "https://github.com/agentos-mcp/server/issues"
  },
  "homepage": "https://github.com/agentos-mcp/server#readme"
}
